# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Deal Tracker / CRM — server-only secrets (no NEXT_PUBLIC_ prefix)
# Service role key: used by the email-sync route to store Graph tokens and
# write synced emails (bypasses RLS). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Microsoft Graph (Azure app registration) — for Outlook email sync + login
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
